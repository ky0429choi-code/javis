# JARVIS 환경 설정 (개발 환경)
# 복사: cp .env.example .env
# 그 후 .env 파일을 자신의 환경에 맞게 수정하세요

# ===== APPLICATION 설정 =====
APP_NAME=Jarvis Agent Office v5.0
APP_ENV=local
APP_VERSION=5.0

# ===== BACKEND 설정 =====
PORT=8000
HOST=127.0.0.1

# ===== OLLAMA LLM 설정 =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_PATH=/api/chat
OLLAMA_TIMEOUT=60
LLM_RETRY_COUNT=3

# 모델명: jarvis, llama2, mistral, neural-chat, orca2
JARVIS_MODEL=JARVIS:latest
GPT_OSS_MODEL=gpt-oss:latest
QWEN_MODEL=qwen2.5-coder:latest

# ===== 데이터베이스 =====
SQLITE_PATH=./data/jarvis.db
DATABASE_URL=sqlite:///./jarvis.db

# ===== API 보안 =====
APP_SHARED_KEY=AIN_PAPA_SHARED_KEY
SECRET_KEY=your-secret-key-change-this-in-production

# ===== 로깅 =====
LOG_LEVEL=INFO

# ===== 개발/배포 =====
DEBUG=true
ENVIRONMENT=local

# ===== 파일 경로 =====
PROMPTS_DIR=./prompts
LOGS_DIR=./logs
DATA_DIR=./data

# ===== 기능 활성화 =====
ENABLE_FILE_OPERATIONS=true
ENABLE_APPROVAL_ENGINE=true
ENABLE_WIKI_AGENT=true

# ===== 제한 설정 =====
MAX_MESSAGE_LENGTH=10000
MAX_RESPONSE_LENGTH=5000
REQUEST_TIMEOUT=30
