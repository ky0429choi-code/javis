# ==================== JARVIS 환경 설정 (.env) ====================
# 이 파일을 .env로 복사하여 사용하세요

# ==================== 애플리케이션 설정 ====================
APP_NAME=Jarvis Agent Office
APP_ENV=local                          # local | staging | production
APP_SHARED_KEY=AIN_PAPA_SHARED_KEY

# ==================== LLM 모드 (핵심 설정) ====================
# 로컬 개발/데모: local
# 클라우드 배포 (Railway/AWS): cloud
# 하이브리드 (로컬 우선, 실패 시 클라우드): hybrid
# 오프라인 (테스트용): offline
LLM_MODE=hybrid

# ==================== 로컬 Ollama 설정 ====================
# 로컬 Ollama가 실행 중인 주소
# 개발 PC: http://localhost:11434
# Docker Compose: http://ollama:11434
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=jarvis

# Ollama 연결 설정
OLLAMA_TIMEOUT=60                      # 타임아웃 (초)
OLLAMA_RETRY_ATTEMPTS=3                # 재시도 횟수
OLLAMA_RETRY_DELAY=3                   # 재시도 지연 (초)

# ==================== 클라우드 API 설정 ====================
# Railway, AWS, GCP 배포 시 사용
CLOUD_PROVIDER=openai                  # openai | anthropic | vertex

# --- OpenAI 설정 ---
# https://platform.openai.com/api-keys에서 발급
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4-mini                # gpt-4 | gpt-4-turbo | gpt-4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic (Claude) 설정 ---
# https://console.anthropic.com에서 발급
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307   # claude-3-opus | claude-3-sonnet | claude-3-haiku

# --- Google Vertex AI 설정 ---
# (아직 미구현)
GEMINI_API_KEY=

# ==================== 데이터베이스 ====================
SQLITE_PATH=../data/jarvis.db

# ==================== 보관함 경로 ====================
AX_VAULT_PATH=../AX_Vault

# ==================== 로깅 ====================
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
DEBUG_MODE=false

# ==================== 레거시 설정 (호환성용) ====================
# 아래는 이전 코드와의 호환성을 위해 유지합니다
# LLM_MODE 사용을 권장합니다
INTELLIGENCE_ENGINE_URL=http://localhost:11434
INTELLIGENCE_ENGINE_CHAT_PATH=/api/chat
JARVIS_MODEL=JARVIS
GPT_OSS_MODEL=gpt-oss:latest
GEMMA_MODEL=gemma3:4b
QWEN_MODEL=qwen2.5-coder:latest
USE_EXTERNAL_API=false


# ==================== 배포 환경별 추천 설정 ====================
# 
# 🔵 로컬 개발 (PC에서 Ollama 실행)
# LLM_MODE=local
# LOCAL_OLLAMA_URL=http://localhost:11434
#
# 🔵 로컬 개발 (Ollama 오프라인)
# LLM_MODE=cloud
# OPENAI_API_KEY=sk-proj-...
#
# 🟢 Docker Compose (로컬 Ollama + FastAPI)
# LLM_MODE=hybrid
# LOCAL_OLLAMA_URL=http://ollama:11434
# OPENAI_API_KEY=sk-proj-...
#
# 🟢 Railway 배포 (클라우드 API 필수)
# LLM_MODE=cloud
# OPENAI_API_KEY=sk-proj-...
#
# 🟢 Railway 배포 (하이브리드 권장)
# LLM_MODE=hybrid
# LOCAL_OLLAMA_URL=http://localhost:11434  (Railway에 Ollama 없으므로 자동 폴백)
# OPENAI_API_KEY=sk-proj-...
#
# 🟢 AWS EC2 + Docker (Ollama 컨테이너 포함)
# LLM_MODE=hybrid
# LOCAL_OLLAMA_URL=http://ollama:11434
# OPENAI_API_KEY=sk-proj-...
#
# ==================== 추천 구성 ====================
#
# 비용 최소: LLM_MODE=local (Ollama만 사용, 100% 무료)
# 안정성 중심: LLM_MODE=hybrid + OPENAI_API_KEY (로컬 실패 시 API)
# 가장 간단: LLM_MODE=cloud + OPENAI_API_KEY (항상 API 사용)
#
