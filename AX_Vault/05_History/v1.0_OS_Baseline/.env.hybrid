# ==================== JARVIS 하이브리드 리소스 설정 ====================
# 로컬 PC + 무료 클라우드 최대 활용 구성

# ==================== LLM 라우팅 설정 ====================

# 라우팅 모드
# - local: 로컬 Ollama만 사용
# - cloud: 클라우드 API만 사용 (무료 옵션)
# - hybrid: 로컬 시도 → 실패시 클라우드 (추천)
LLM_MODE=hybrid

# 로컬 Ollama 설정
LOCAL_OLLAMA_URL=http://localhost:11434
LOCAL_OLLAMA_MODEL=jarvis
OLLAMA_KEEP_ALIVE=5m  # 5분 동안 메모리 유지

# ==================== 무료 LLM API 설정 ====================

# Groq (무료 - Mixtral 8x7B)
# 가입: https://console.groq.com
# 한도: 무제한 (API 속도 제약만 있음)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=mixtral-8x7b-32768

# HuggingFace (무료)
# 가입: https://huggingface.co/settings/tokens
# 한도: 무제한 (단, 동시 요청 제한)
HUGGINGFACE_API_KEY=hf_your_token_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Anthropic Claude (가장 저렴)
# 가입: https://console.anthropic.com
# 가격: $0.25/$0.75 per M tokens (매우 저렴)
# 추천: 복잡한 작업에 최적
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# OpenAI (배치 모드 50% 할인)
# 가입: https://platform.openai.com
# 특징: 배치 처리시 비용 50% 할인
# 추천: 대용량 배치 처리
OPENAI_API_KEY=sk-your_key_here
OPENAI_BATCH_MODE=true  # 배치 모드 활성화

# ==================== 캐시 설정 ====================

# Redis (빠른 캐시, L1)
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_TTL=3600  # 1시간

# SQLite (장기 캐시, L2)
SQLITE_CACHE_DB=cache.db
SQLITE_CACHE_RETENTION_DAYS=30

# 캐시 설정
CACHE_ENABLE=true
CACHE_L1_TTL=3600      # Redis: 1시간
CACHE_L2_TTL=2592000   # SQLite: 30일

# ==================== 응답 우선순위 ====================

# 즉시 응답 필요한 작업 (chat)
PRIORITY_IMMEDIATE=local_ollama,groq,huggingface

# 복잡한 작업 (code generation, analysis)
PRIORITY_COMPLEX=claude_haiku,groq,openai_batch

# 대용량 작업 (bulk processing)
PRIORITY_BULK=openai_batch,local_queue

# ==================== 성능 모니터링 ====================

# 응답 시간 로깅
LOG_RESPONSE_TIME=true
LOG_RESPONSE_TIME_THRESHOLD_MS=2000  # 2초 이상 경고

# 비용 추적
TRACK_COSTS=true
MONTHLY_BUDGET=5  # 월 예산 $5

# ==================== 클라우드 저장소 (무료 옵션) ====================

# Supabase (PostgreSQL + 실시간)
# 가입: https://supabase.com
# 무료: 500MB 저장소, 무제한 API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# Firebase (NoSQL + 실시간)
# 가입: https://console.firebase.google.com
# 무료: 1GB 저장소, 동시 연결 100개
FIREBASE_PROJECT_ID=your_project
FIREBASE_API_KEY=your_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com

# ==================== 배치 처리 ====================

# 처리 대기 큐 활성화
TASK_QUEUE_ENABLE=true
TASK_QUEUE_MAX_WORKERS=4  # 로컬 동시 작업 수

# 배치 작업 설정
BATCH_JOB_MAX_ITEMS=1000  # 배치당 최대 항목
BATCH_JOB_TIMEOUT_HOURS=24  # 배치 타임아웃

# ==================== 모니터링 대시보드 ====================

# 통계 수집
COLLECT_STATS=true
STATS_INTERVAL_SECONDS=60

# 메트릭 저장
SAVE_METRICS_TO_DB=true
METRICS_RETENTION_DAYS=90  # 90일 메트릭 보관

# 경고 설정
ALERT_HIGH_LATENCY_MS=5000       # 5초 이상 경고
ALERT_ERROR_RATE_PERCENT=10      # 10% 이상 에러율 경고
ALERT_COST_EXCEED_PERCENT=80    # 예산의 80% 이상 경고

# ==================== 개발/테스트 모드 ====================

DEBUG=false
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# API 응답 로깅
LOG_API_CALLS=true

# 테스트용 모의 응답
MOCK_MODE=false

# ==================== 배포 환경 ====================

# 호스트 설정
HOST=127.0.0.1
PORT=8000

# Railway 배포용
RAILWAY_ENVIRONMENT_NAME=production  # production | staging | development
RAILWAY_LINK=https://jarvis-railway.up.railway.app

# ==================== 보안 ====================

# API 키 유효성 검사
VALIDATE_API_KEYS_ON_STARTUP=true

# CORS 설정
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# 요청 로깅 (민감한 정보 제외)
SANITIZE_LOGS=true
MASK_API_KEYS=true
